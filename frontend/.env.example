# Ghost Bazaar Frontend Environment Variables
# Copy to .env.local for local development

# Engine proxy target (dev only):
#   local → http://localhost:3000 (run engine locally)
#   fly   → https://ghost-bazaar-engine.fly.dev (use production engine)
ENGINE=fly

# Browser-side API URL (Vercel production only):
# VITE_API_URL=https://ghost-bazaar-engine.fly.dev
